#!/usr/bin/env bash

printMarkdownSyntax()
{
  echo "Markdown 语法指南："
  echo ""
  echo " 换行：在上一行的末尾添加两个空格"
  echo ""
  echo " 标题：使用多个井号表示不同级别的标题，例如 # 一级标题"
  echo ""
  echo " 加粗：使用两个星号或下划线包围文字，例如 **加粗** 或 __加粗__"
  echo ""
  echo " 斜体：使用一个星号或下划线包围文字，例如 *斜体* 或 _斜体_"
  echo ""
  echo " 删除线：使用两个波浪线包围文字，例如 ~~删除线~~"
  echo ""
  echo " 分割线：在单独的一行上，使用三个或更多的星号或减号，例如 --- 或 ***"
  echo ""
  echo " 下划线： Markdown 本身不直接支持下划线，但可以通过 HTML 标签实现，例如 <u>下划线</u>"
  echo ""
  echo " 列表：无序列表使用星号、加号或减号，有序列表使用数字加点，例如 - 无序列表项"
  echo "嵌套列表：通过增加缩进(2个空格)实现，例如"
  echo "  - 一级列表项"
  echo "    - 二级列表项"
  echo " 退出列表：在列表后添加一行空行"
  echo ""
  echo " 勾选框：在列表项前添加 [ ] 或 [x] (没有或有x表示未选中或选中)，例如 - [x] 已完成"
  echo ""
  echo '行内代码：`这是一段行内代码`'
  echo " 代码块：使用三个反引号包围代码，可以指定语言，例如"
  echo '   ```bash'
  echo '   echo "Hello World"'
  echo '   ```'
  echo ""
  echo " 引用：使用大于号，例如 > 这是一个引用"
  echo " 退出引用：在引用后添加一行空行"
  echo ""
  echo " 链接和图片：链接使用 [链接文字](URL) ，图片使用 ![替代文字](图片URL)，例如 [Google](https://googlecom)"
  echo ""
  echo " 脚注：使用脚注标记 [^]，然后在文档的其他地方定义脚注，例如 带脚注[^1]的文本 [^1]: 脚注的内容"
  echo ""
  echo " 表格：使用竖线和减号定义表格，例如"
  echo "| 左对齐 | 居中 | 右对齐 |"
  echo "|:-------|:----:|-------:|"
  echo "| 单元格 | 单元格 | 单元格 |"
  echo "| 单元格 | 单元格 | 单元格 |"
  echo ""
}

printMathSyntaxInMarkdown()
{
  echo
  echo "Markdown 中的数学公式语法指南："
  echo ""
  echo '公式行：使用一个美元符号将公式包围，例如 $公式$'
  echo '公式块：使用两个美元符号将公式包围，例如  $$公式$$'
  echo ""
  echo "比较大小：使用 >, <, \geq, \leq 表示，例如"
  echo '  $$x > y, x < y, x \geq y, x \leq y$$'
  echo ""
  echo "乘除号：使用 \times, \div 表示，例如"
  echo '  $$x \times y, \frac{x}{y}$$'
  echo ""
  echo "累乘（乘积）：使用 \prod 表示，例如"
  echo '  $$\prod_{i=1}^{n} x_i$$'
  echo ""
  echo "平均值：使用 \overline 表示，例如"
  echo '  $$\overline{x} = \frac{1}{n} \sum_{i=1}^{n} x_i$$'
  echo ""
  echo "对数：使用 \log 表示，例如"
  echo '  $$\log(x), \ln(x)$$'
  echo ""
  echo "三角函数：使用 \sin, \cos, \tan 表示，例如"
  echo '  $$\sin(x), \cos(x), \tan(x)$$'
  echo ""
  echo "集合：使用 \{ 和 \} 表示，例如"
  echo '  $$\{x | x > 0\}$$'
  echo ""
  echo "特殊符号：例如无穷大 \infty，属于 \in，不属于 \notin，空集 \emptyset，等等。"
  echo '  $$x \in \mathbb{R}, \emptyset, x \notin \emptyset$$'
  echo ""
  echo "特殊数学符号：例如希腊字母"
  echo '  $$\alpha, \beta, \gamma, \sigma, \delta$$'
  echo ""
  echo "分数：使用 \frac{分子}{分母}，例如"
  echo '  $$\frac{a}{b}$$'
  echo ""
  echo "开方：使用 \sqrt{表达式}，例如"
  echo '  $$\sqrt{x}, \sqrt[n]{x}$$'
  echo ""
  echo "上下标：上标使用 ^，下标使用 _，如果上标或下标内容多于一个字符，需要使用 {} 括起来。例如"
  echo '  $$x^2, x_i, E=mc^2$$'
  echo ""
  echo "积分：使用 \int_{下限}^{上限}，例如"
  echo '  $$\int_{a}^{b} x^2 dx$$'
  echo ""
  echo "极限：使用 \lim_{趋近值} 表达式，例如"
  echo '  $$\lim_{x \to \infty} \frac{1}{x}$$'
  echo ""
  echo "向量：使用 \vec{向量}，例如"
  echo '  $$\vec{v} = x\vec{i} + y\vec{j}$$'
  echo ""
  echo "省略号：使用 \ldots（靠下面）和 \cdots（靠中间），例如"
  echo '  $$1, 2, \ldots, n$$'
  echo '  $$x_1 + x_2 + \cdots + x_n$$'
  echo ""
  echo "点乘：使用 \cdot，例如"
  echo '  $$a \cdot b$$'
  echo ""
  echo "累加：使用 \sum_{下限}^{上限} 表达式，例如"
  echo '  $$\sum_{i=1}^{n} i^2$$'
  echo ""
  echo "矩阵：使用 \begin{matrix} 和 \end{matrix}，并用 & 分隔列，\\ 分隔行，例如"
  echo '  $$\begin{matrix} a & b \\ c & d \end{matrix}$$'
  echo ""
}

printMarkdownSyntax
echo '-----------------------------------------------------------------------'
printMathSyntaxInMarkdown
